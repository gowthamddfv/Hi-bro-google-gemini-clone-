{
  "entities": {
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "updatedAt": { "type": "number" },
        "messages": { "type": "array" }
      },
      "required": ["id", "title", "updatedAt", "messages"]
    }
  },
  "firestore": {
    "users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "User's chat sessions."
    }
  }
}
