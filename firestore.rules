rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'title', 'updatedAt', 'messages']) 
        && data.keys().size() == 4
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 500
        && data.updatedAt is number
        && data.messages is list && data.messages.size() <= 1000;
    }

    match /users/{userId}/sessions/{sessionId} {
      allow read, list: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId 
                    && isValidId(sessionId)
                    && isValidSession(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId
                    && isValidSession(incoming());
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
